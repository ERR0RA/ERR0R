<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Multiplayer Fighter Prototype</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: #111;
      color: #eee;
      font-family: system-ui, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      height: 100vh;
    }

    h1 {
      margin: 10px 0;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    #game-container {
      position: relative;
      border: 3px solid #444;
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
      margin-top: 10px;
    }

    canvas {
      display: block;
      background: radial-gradient(circle at 50% 0%, #555 0, #222 40%, #000 100%);
    }

    #hud {
      width: 800px;
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      color: #eee;
      font-size: 14px;
    }

    .health-bar-container {
      width: 45%;
      height: 20px;
      border: 2px solid #555;
      background: #222;
      position: relative;
      overflow: hidden;
    }

    .health-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      background: linear-gradient(90deg, #0f0, #ff0, #f00);
      transform-origin: left center;
    }

    .player-label {
      margin-bottom: 4px;
      font-weight: bold;
      text-shadow: 0 0 5px #000;
    }

    #info {
      width: 800px;
      margin-top: 10px;
      font-size: 13px;
      color: #ccc;
      line-height: 1.4;
    }

    #info code {
      background: #222;
      padding: 2px 4px;
      border-radius: 3px;
      color: #9cf;
    }

    #status {
      margin-top: 6px;
      font-size: 12px;
      color: #9f9;
    }
  </style>
</head>
<body>
  <h1>Multiplayer Fighter Prototype</h1>

  <div id="game-container">
    <canvas id="game" width="800" height="450"></canvas>
  </div>

  <div id="hud">
    <div>
      <div class="player-label">Player 1 (A/D to move, W to jump, F to punch)</div>
      <div class="health-bar-container">
        <div id="healthP1" class="health-bar"></div>
      </div>
    </div>
    <div style="text-align: right;">
      <div class="player-label">Player 2 (←/→ to move, ↑ to jump, K to punch)</div>
      <div class="health-bar-container">
        <div id="healthP2" class="health-bar"></div>
      </div>
    </div>
  </div>

  <div id="info">
    <p>
      This is a <strong>local multiplayer</strong> prototype. To turn it into an online game,
      connect the <code>Network</code> object to a WebSocket server and sync player states.
    </p>
    <p>
      Ideas to make it “highly realistic”:
      use high‑res sprite sheets, skeletal animation (e.g. Spine), dynamic lighting,
      hit sparks, camera shake, and sound effects.
    </p>
    <div id="status">Status: Local mode (no server connected)</div>
  </div>

  <script>
    // =========================
    // Utility helpers
    // =========================
    function clamp(v, min, max) {
      return Math.max(min, Math.min(max, v));
    }

    // =========================
    // Input handling
    // =========================
    const keys = {};
    window.addEventListener("keydown", (e) => {
      keys[e.code] = true;
    });
    window.addEventListener("keyup", (e) => {
      keys[e.code] = false;
    });

    // =========================
    // Network placeholder
    // =========================
    const Network = {
      mode: "local", // "local" or "online"
      connected: false,
      lastSnapshot: null,

      connect() {
        // In a real game, you’d open a WebSocket here.
        // For now, we just simulate local mode.
        this.mode = "local";
        this.connected = false;
        updateStatus("Status: Local mode (no server connected)");
      },

      sendState(state) {
        // In online mode, serialize and send to server.
        this.lastSnapshot = state;
      },

      receiveState() {
        // In online mode, this would be called when server sends updates.
        return this.lastSnapshot;
      },
    };

    function updateStatus(text) {
      const el = document.getElementById("status");
      if (el) el.textContent = text;
    }

    // =========================
    // Game constants
    // =========================
    const canvas = document.getElementById("game");
    const ctx = canvas.getContext("2d");

    const FLOOR_Y = 380;
    const GRAVITY = 0.8;
    const FRICTION = 0.8;
    const MOVE_SPEED = 4;
    const JUMP_FORCE = -14;
    const PUNCH_RANGE = 60;
    const PUNCH_COOLDOWN = 400; // ms
    const DAMAGE = 10;

    // =========================
    // Fighter class
    // =========================
    class Fighter {
      constructor(options) {
        this.x = options.x;
        this.y = options.y;
        this.width = 50;
        this.height = 100;
        this.color = options.color;
        this.facing = options.facing || 1; // 1 = right, -1 = left
        this.vx = 0;
        this.vy = 0;
        this.onGround = false;
        this.health = 100;
        this.maxHealth = 100;
        this.isPunching = false;
        this.lastPunchTime = 0;
        this.name = options.name || "Fighter";
      }

      getHitbox() {
        return {
          x: this.x - this.width / 2,
          y: this.y - this.height,
          width: this.width,
          height: this.height,
        };
      }

      getPunchBox() {
        const hb = this.getHitbox();
        const dir = this.facing;
        return {
          x: dir === 1 ? hb.x + hb.width : hb.x - PUNCH_RANGE,
          y: hb.y + hb.height * 0.3,
          width: PUNCH_RANGE,
          height: hb.height * 0.4,
        };
      }

      takeDamage(amount) {
        this.health = clamp(this.health - amount, 0, this.maxHealth);
      }

      canPunch() {
        const now = performance.now();
        return now - this.lastPunchTime > PUNCH_COOLDOWN;
      }

      punch() {
        if (!this.canPunch()) return;
        this.isPunching = true;
        this.lastPunchTime = performance.now();
        setTimeout(() => {
          this.isPunching = false;
        }, 120);
      }

      updatePhysics() {
        // Apply gravity
        this.vy += GRAVITY;

        // Apply friction
        this.vx *= FRICTION;

        // Integrate
        this.x += this.vx;
        this.y += this.vy;

        // Floor collision
        if (this.y > FLOOR_Y) {
          this.y = FLOOR_Y;
          this.vy = 0;
          this.onGround = true;
        } else {
          this.onGround = false;
        }

        // World bounds
        this.x = clamp(this.x, 50, canvas.width - 50);
      }

      draw(ctx) {
        const hb = this.getHitbox();

        // Shadow
        ctx.save();
        ctx.fillStyle = "rgba(0,0,0,0.5)";
        const shadowWidth = this.width * 0.8;
        const shadowHeight = 15;
        ctx.beginPath();
        ctx.ellipse(
          this.x,
          FLOOR_Y + 5,
          shadowWidth / 2,
          shadowHeight / 2,
          0,
          0,
          Math.PI * 2
        );
        ctx.fill();
        ctx.restore();

        // Body
        const gradient = ctx.createLinearGradient(
          hb.x,
          hb.y,
          hb.x + hb.width,
          hb.y + hb.height
        );
        gradient.addColorStop(0, this.color);
        gradient.addColorStop(1, "#111");

        ctx.save();
        ctx.fillStyle = gradient;
        ctx.strokeStyle = "#000";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.roundRect(hb.x, hb.y, hb.width, hb.height, 10);
        ctx.fill();
        ctx.stroke();

        // Head
        ctx.beginPath();
        ctx.arc(this.x, hb.y - 20, 18, 0, Math.PI * 2);
        ctx.fillStyle = "#f5d7b2";
        ctx.fill();
        ctx.stroke();

        // Simple face
        ctx.fillStyle = "#000";
        const eyeOffsetX = 6 * this.facing;
        ctx.beginPath();
        ctx.arc(this.x + eyeOffsetX, hb.y - 22, 3, 0, Math.PI * 2);
        ctx.fill();

        // Punch effect
        if (this.isPunching) {
          const pb = this.getPunchBox();
          const punchGrad = ctx.createLinearGradient(
            pb.x,
            pb.y,
            pb.x + pb.width,
            pb.y + pb.height
          );
          punchGrad.addColorStop(0, "rgba(255,255,255,0.8)");
          punchGrad.addColorStop(1, "rgba(255,200,0,0.2)");
          ctx.fillStyle = punchGrad;
          ctx.beginPath();
          ctx.roundRect(pb.x, pb.y, pb.width, pb.height, 8);
          ctx.fill();
        }

        ctx.restore();
      }
    }

    // =========================
    // Game state
    // =========================
    const player1 = new Fighter({
      x: 200,
      y: FLOOR_Y,
      color: "#3af",
      facing: 1,
      name: "Player 1",
    });

    const player2 = new Fighter({
      x: 600,
      y: FLOOR_Y,
      color: "#f33",
      facing: -1,
      name: "Player 2",
    });

    function resetRound() {
      player1.x = 200;
      player1.y = FLOOR_Y;
      player1.vx = 0;
      player1.vy = 0;
      player1.health = player1.maxHealth;
      player1.facing = 1;

      player2.x = 600;
      player2.y = FLOOR_Y;
      player2.vx = 0;
      player2.vy = 0;
      player2.health = player2.maxHealth;
      player2.facing = -1;
    }

    // =========================
    // Collision helpers
    // =========================
    function rectsOverlap(a, b) {
      return !(
        a.x + a.width < b.x ||
        a.x > b.x + b.width ||
        a.y + a.height < b.y ||
        a.y > b.y + b.height
      );
    }

    // =========================
    // Input → movement
    // =========================
    function handleInput() {
      // Player 1: A/D move, W jump, F punch
      if (keys["KeyA"]) {
        player1.vx = -MOVE_SPEED;
        player1.facing = -1;
      } else if (keys["KeyD"]) {
        player1.vx = MOVE_SPEED;
        player1.facing = 1;
      }

      if (keys["KeyW"] && player1.onGround) {
        player1.vy = JUMP_FORCE;
      }

      if (keys["KeyF"]) {
        player1.punch();
      }

      // Player 2: ArrowLeft/Right move, ArrowUp jump, KeyK punch
      if (keys["ArrowLeft"]) {
        player2.vx = -MOVE_SPEED;
        player2.facing = -1;
      } else if (keys["ArrowRight"]) {
        player2.vx = MOVE_SPEED;
        player2.facing = 1;
      }

      if (keys["ArrowUp"] && player2.onGround) {
        player2.vy = JUMP_FORCE;
      }

      if (keys["KeyK"]) {
        player2.punch();
      }
    }

    // =========================
    // Combat logic
    // =========================
    function handleCombat() {
      const hb1 = player1.getHitbox();
      const hb2 = player2.getHitbox();

      // Keep fighters from overlapping too much
      const minDistance = 40;
      const dx = player2.x - player1.x;
      if (Math.abs(dx) < minDistance) {
        const push = (minDistance - Math.abs(dx)) / 2;
        if (dx > 0) {
          player1.x -= push;
          player2.x += push;
        } else {
          player1.x += push;
          player2.x -= push;
        }
      }

      // Punch detection
      if (player1.isPunching && player1.canPunch() === false) {
        const pb1 = player1.getPunchBox();
        if (rectsOverlap(pb1, hb2)) {
          player2.takeDamage(DAMAGE);
        }
      }

      if (player2.isPunching && player2.canPunch() === false) {
        const pb2 = player2.getPunchBox();
        if (rectsOverlap(pb2, hb1)) {
          player1.takeDamage(DAMAGE);
        }
      }

      // Round end
      if (player1.health <= 0 || player2.health <= 0) {
        setTimeout(() => {
          resetRound();
        }, 1000);
      }
    }

    // =========================
    // Rendering
    // =========================
    function drawBackground() {
      // Sky gradient
      const skyGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
      skyGrad.addColorStop(0, "#1b1f3b");
      skyGrad.addColorStop(0.5, "#222");
      skyGrad.addColorStop(1, "#111");
      ctx.fillStyle = skyGrad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Distant city silhouettes
      ctx.save();
      ctx.fillStyle = "#181818";
      for (let i = 0; i < 10; i++) {
        const w = 60 + Math.random() * 80;
        const h = 80 + Math.random() * 120;
        const x = i * 80 + Math.random() * 20;
        const y = FLOOR_Y - h - 60;
        ctx.fillRect(x, y, w, h);
      }
      ctx.restore();

      // Floor
      ctx.save();
      const floorGrad = ctx.createLinearGradient(
        0,
        FLOOR_Y,
        0,
        canvas.height
      );
      floorGrad.addColorStop(0, "#333");
      floorGrad.addColorStop(1, "#111");
      ctx.fillStyle = floorGrad;
      ctx.fillRect(0, FLOOR_Y, canvas.width, canvas.height - FLOOR_Y);

      // Floor lines
      ctx.strokeStyle = "rgba(255,255,255,0.05)";
      ctx.lineWidth = 1;
      for (let i = 0; i < 10; i++) {
        ctx.beginPath();
        ctx.moveTo(0, FLOOR_Y + i * 8);
        ctx.lineTo(canvas.width, FLOOR_Y + i * 8);
        ctx.stroke();
      }
      ctx.restore();

      // Spotlights
      ctx.save();
      ctx.globalCompositeOperation = "lighter";
      const spotlight = ctx.createRadialGradient(
        canvas.width * 0.25,
        0,
        0,
        canvas.width * 0.25,
        0,
        300
      );
      spotlight.addColorStop(0, "rgba(255,255,255,0.25)");
      spotlight.addColorStop(1, "rgba(255,255,255,0)");
      ctx.fillStyle = spotlight;
      ctx.beginPath();
      ctx.arc(canvas.width * 0.25, 0, 300, 0, Math.PI * 2);
      ctx.fill();

      const spotlight2 = ctx.createRadialGradient(
        canvas.width * 0.75,
        0,
        0,
        canvas.width * 0.75,
        0,
        300
      );
      spotlight2.addColorStop(0, "rgba(255,255,255,0.25)");
      spotlight2.addColorStop(1, "rgba(255,255,255,0)");
      ctx.fillStyle = spotlight2;
      ctx.beginPath();
      ctx.arc(canvas.width * 0.75, 0, 300, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    function updateHealthBars() {
      const p1Bar = document.getElementById("healthP1");
      const p2Bar = document.getElementById("healthP2");
      if (!p1Bar || !p2Bar) return;

      const p1Ratio = player1.health / player1.maxHealth;
      const p2Ratio = player2.health / player2.maxHealth;

      p1Bar.style.transform = `scaleX(${p1Ratio})`;
      p2Bar.style.transform = `scaleX(${p2Ratio})`;
      p2Bar.style.transformOrigin = "right center";
    }

    // =========================
    // Main loop
    // =========================
    let lastTime = 0;

    function gameLoop(timestamp) {
      const dt = timestamp - lastTime;
      lastTime = timestamp;

      handleInput();
      player1.updatePhysics();
      player2.updatePhysics();
      handleCombat();

      // Networking placeholder
      Network.sendState({
        p1: { x: player1.x, y: player1.y, health: player1.health },
        p2: { x: player2.x, y: player2.y, health: player2.health },
      });

      drawBackground();
      player1.draw(ctx);
      player2.draw(ctx);
      updateHealthBars();

      requestAnimationFrame(gameLoop);
    }

    // =========================
    // Init
    // =========================
    resetRound();
    Network.connect();
    requestAnimationFrame(gameLoop);
  </script>
</body>
</html>
